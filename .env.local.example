# =====================================================================
# EL KIRAT-ART — Variables d'environnement
# Copiez ce fichier en `.env.local` et renseignez les valeurs réelles.
# NE JAMAIS committer `.env.local` sur GitHub (déjà ignoré dans .gitignore).
# =====================================================================

# --- Supabase (publiques, exposées au navigateur) ---
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key

# --- Supabase (PRIVÉE — uniquement côté serveur, jamais exposée au client) ---
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# --- Identifiants administrateur (privés, validés côté serveur) ---
# Choisissez vos propres identifiants — ne JAMAIS mettre les vrais ici.
ADMIN_USERNAME=votre_identifiant_admin
ADMIN_PASSWORD=votre_mot_de_passe_admin

# --- Secret de session (signe le cookie d'authentification admin) ---
# Générez une valeur aléatoire forte, ex: `openssl rand -base64 32`
SESSION_SECRET=remplacez_par_une_chaine_aleatoire_longue_et_secrete

# --- Nom du bucket Supabase Storage pour les images ---
NEXT_PUBLIC_SUPABASE_BUCKET=paintings
